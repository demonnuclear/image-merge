#!/bin/bash

SERVER_DIR="${TRIM_APPDEST}/server"
PID_FILE="${TRIM_PKGVAR}/app.pid"
LOG_FILE="${TRIM_PKGVAR}/app.log"

# Detect Python
PYTHON=""
if command -v python3 &>/dev/null; then
    PYTHON="python3"
elif command -v python &>/dev/null; then
    PYTHON="python"
else
    echo "Python 3 not found" > "$TRIM_TEMP_LOGFILE"
    exit 1
fi

check_process() {
    local pid=$1
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null && return 0
    return 1
}

is_running() {
    [ -f "$PID_FILE" ] || return 1
    local pid
    pid=$(head -n 1 "$PID_FILE" | tr -d '[:space:]')
    if check_process "$pid"; then
        return 0
    fi
    rm -f "$PID_FILE"
    return 1
}

case $1 in
start)
    if is_running; then
        exit 0
    fi
    cd "$SERVER_DIR" || exit 1
    nohup $PYTHON main.py >> "$LOG_FILE" 2>&1 &
    printf "%s" "$!" > "$PID_FILE"
    sleep 2
    if is_running; then
        exit 0
    else
        echo "Failed to start application" > "$TRIM_TEMP_LOGFILE"
        exit 1
    fi
    ;;
stop)
    if [ ! -f "$PID_FILE" ]; then
        exit 0
    fi
    local pid
    pid=$(head -n 1 "$PID_FILE" | tr -d '[:space:]')
    if check_process "$pid"; then
        kill -TERM "$pid" 2>/dev/null
        local count=0
        while check_process "$pid" && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
        done
        if check_process "$pid"; then
            kill -KILL "$pid" 2>/dev/null
            sleep 1
        fi
    fi
    rm -f "$PID_FILE"
    exit 0
    ;;
status)
    if is_running; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
